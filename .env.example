# ========== 数据源配置（必填，替换为你的实际地址） ==========
REMOTE_JSON_URL=https://www.liublog.cn/flink_count.json  # 远程友链JSON地址
LOCAL_JSON_PATH=./flink_count.json                       # 本地兜底JSON路径

# ========== 检测配置（可选，保持默认即可稳定运行） ==========
CHECK_TIMEOUT=10          # 链接检测超时时间（秒），10秒足够稳定
MAX_WORKERS=3             # 并发检测数，3个并发避免被封IP
RETRY_TIMES=1             # 失败重试次数，1次兼顾效率和成功率

# ========== 日志配置（可选） ==========
LOG_LEVEL=INFO            # 日志级别：DEBUG/INFO/WARNING/ERROR（INFO最稳定）
LOG_RETENTION_DAYS=7      # 日志保留天数

# ========== 服务器配置（仅服务器端生效） ==========
API_PORT=8000             # 预留端口（暂未使用）
CRON_EXPR=0 9 * * *       # 服务器定时任务（每天9点）
INSTALL_DIR=/opt/flink_check  # 服务器安装目录