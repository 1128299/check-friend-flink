# ========== 数据源配置（必填，替换为你的实际地址） ==========
REMOTE_JSON_URL=https://www.liublog.cn/flink_count.json  # 友链数据源
LOCAL_JSON_PATH=./flink_count.json                       # 本地兜底数据源

# ========== 检测配置（可选，双端通用） ==========
CHECK_TIMEOUT=10          # 检测超时时间（秒）
MAX_WORKERS=3             # 并发检测数（服务器/GitHub通用）
RETRY_TIMES=1             # 失败重试次数

# ========== 日志配置（可选） ==========
LOG_LEVEL=INFO            # 日志级别：DEBUG/INFO/WARNING/ERROR
LOG_RETENTION_DAYS=7      # 日志保留天数（服务器端生效）

# ========== 运行环境标识（自动识别，无需修改） ==========
# RUN_ENV=github  # GitHub端自动设置
# RUN_ENV=server  # 服务器端自动设置
